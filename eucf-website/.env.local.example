# Copy to .env.local and fill in. .env* is git-ignored.
# Build-time Airtable content sync (scripts/sync-airtable.ts).

# Required
# Token scopes: data.records:read AND data.records:write on the base — the
# image pipeline (scripts/sync-images.ts) writes R2 URLs back into records.
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxx       # Airtable personal access token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX        # Airtable base id

# R2 image pipeline (scripts/sync-images.ts) — if any is unset, the image step
# is skipped with a warning and attachments stay in Airtable until it runs.
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Cloudflare dashboard → R2 → account id
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx                # R2 API token (Object Read & Write, scoped to the bucket)
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
R2_BUCKET=eucf-images
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev       # or the bucket's custom domain — no trailing slash

# Optional — only set if table names differ from these defaults
# AIRTABLE_TABLE_TITLES=titles
# AIRTABLE_TABLE_TEAMS=teams
# AIRTABLE_TABLE_PLAYERS=players
# AIRTABLE_TABLE_OFFICERS=officers
# AIRTABLE_TABLE_SPONSORS=sponsors
# AIRTABLE_TABLE_FEATUREDSTORY=featuredstory

# Optional — view used for top-down ordering on tables without an `order` field
# (officers, sponsors, featuredstory). Defaults to "Grid view"; only set these
# if your view is named differently.
# AIRTABLE_VIEW_TITLES=Grid view
# AIRTABLE_VIEW_TEAMS=Grid view
# AIRTABLE_VIEW_OFFICERS=Grid view
# AIRTABLE_VIEW_SPONSORS=Grid view
# AIRTABLE_VIEW_FEATUREDSTORY=Grid view
